# =============================================
# Configuracao do pipeline Madan -> iScholar
# Copie para .env e preencha os valores reais.
# =============================================

# --- API iScholar ---

# URL base da API (mesma para homologacao e producao).
ISCHOLAR_BASE_URL=https://api.ischolar.app

# Token de autorizacao (header X-Autorizacao).
# Para homologacao, gere em: https://madan_homolog.ischolar.com.br/
# Instrucoes: https://ajuda.ischolar.com.br/pt-BR/articles/5680701-acessando-a-api-do-ischolar
ISCHOLAR_API_TOKEN= 

# Codigo da escola (header X-Codigo-Escola).
# IMPORTANTE: use o valor do campo "escola" presente no payload JWT do token.
# Para o Madan, o valor confirmado eh: madan
# (Inicialmente assumiu-se "madan_homolog", mas o JWT real contem "escola":"madan")
ISCHOLAR_CODIGO_ESCOLA=madan

# --- Opcionais ---

# Timeout por requisicao (segundos). Default: 30
# ISCHOLAR_TIMEOUT_SEGUNDOS=30

# Maximo de retries automaticos em erro 5xx (GET). Default: 3
# ISCHOLAR_MAX_RETRIES=3

# --- Fluxo Google Sheets / webhook (obrigatorio no fluxo novo) ---

# Segredo compartilhado usado pelo Apps Script e pelos endpoints externos.
WEBHOOK_SECRET=troque_por_um_segredo_forte_em_producao

# --- Endurecimento do webhook (opcionais, com defaults seguros no codigo) ---

# Limite bruto do corpo HTTP em bytes. Default: 1048576 (1 MiB)
# WEBHOOK_MAX_CONTENT_LENGTH=1048576

# Janela de tolerancia do anti-replay em segundos. Default: 300
# WEBHOOK_AUTH_WINDOW_SECONDS=300

# Limite de linhas aceitas por request no webhook. Default: 2000
# WEBHOOK_MAX_ROWS=2000

# Janela de rate limit em segundos. Default: 60
# WEBHOOK_RATE_LIMIT_WINDOW_SECONDS=60

# Maximo de requests por IP/endpoint dentro da janela. Default: 120
# WEBHOOK_RATE_LIMIT_MAX_REQUESTS=120

# --- Caminhos de banco / dados (opcionais, defaults na raiz do projeto) ---

# JOB_DB_PATH=jobs.sqlite3
# SNAPSHOTS_DIR=snapshots
# VALIDACAO_LOTE_DB=validacoes_lote.db

# APROVACAO_LOTE_DB=aprovacoes_lote.db
# LOTE_ITENS_DB=lote_itens.db
# ENVIO_LOTE_AUDIT_DB=envio_lote_audit.db
# RESULTADO_ENVIO_LOTE_DB=resultados_envio_lote.db

# --- Mapas (opcionais, defaults nos arquivos da raiz do projeto) ---

# MAPA_DISCIPLINAS=mapa_disciplinas.json
# MAPA_AVALIACOES=mapa_avaliacoes.json
# MAPA_PROFESSORES=mapa_professores.json

# --- Logging (opcional) ---

# LOG_FILE=etl_ischolar.log
# LOG_LEVEL=INFO
